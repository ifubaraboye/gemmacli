    "glob": "latest",
    "ink": "^7.0.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.5",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
