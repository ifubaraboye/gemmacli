{
  "name": "gemmacli",
  "version": "0.1.0",
  "description": "A minimal, modern CLI agent powered by OpenRouter",
  "type": "module",
  "main": "src/cli.tsx",
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx src/cli.tsx",
    "watch": "tsx watch --exclude .sessions src/cli.tsx",
